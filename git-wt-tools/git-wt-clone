#!/usr/bin/env bash

# Usage: git wt-clone <url>

set -e # Exit on error

if [ -z "$1" ]; then
    echo -e "\033[0;31mError: Git repository URL is required\033[0m"
    echo "Usage: git wt-clone <url>"
    exit 1
fi

URL="$1"
# Extract the project name from the URL
DIRNAME=$(basename -s .git "$URL")

# Colors
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'
devex_generate_config() {
    local config_file="$1"
    local default_branch="${2:-main}"

    if [ -f "$config_file" ]; then
        echo -e "${YELLOW}Warning: Config file already exists at $config_file, preserving it.${NC}"
        return 0
    fi

    cat > "$config_file" << EOF
# DevEx Manager Configuration
# This file was generated by 'git wt clone'.
# Edit the values below to customize worktree behavior for this repository.

[repo]
# The default base branch for creating new worktrees.
base_branch = $default_branch

# The name of the primary worktree directory.
main_worktree_name = $default_branch

[symlinks]
# Comma-separated list of files and directories to symlink from the main worktree
# into each new worktree. Paths are relative to the worktree root.
# Symlinked paths share the same underlying file — changes in one worktree
# are reflected in all others.
paths = .claude,.kiro,.vscode

[copies]
# Comma-separated list of files and directories to copy from the main worktree
# into each new worktree. Paths are relative to the worktree root.
# Copied paths are independent — each worktree gets its own copy that can
# diverge from the original.
paths =

[worktree]
# How to derive the worktree folder name from the branch name.
# Options:
#   ticket-prefix  - Use first two hyphen-delimited segments (e.g., JIRA-1234)
#   full-branch    - Use the full branch name (/ replaced with --)
#   custom         - Use a custom folder name passed as the last argument to 'git wt add'
naming_strategy = ticket-prefix
EOF

    echo -e "${GREEN}Config file created: $config_file${NC}"
}

echo -e "${BLUE}Setting up bare clone for $DIRNAME...${NC}"

if [ -d "$DIRNAME" ] && [ "$(ls -A "$DIRNAME")" ]; then
    echo -e "${RED}Error: Directory '$DIRNAME' already exists and is not empty.${NC}"
    exit 1
fi

mkdir -p "$DIRNAME"
cd "$DIRNAME" || exit

echo -e "${GREEN}[1/5] Cloning bare repository...${NC}"
git clone "$URL" --bare .git

echo -e "${GREEN}[2/5] Configuring remote fetch...${NC}"
# Use the correct git directory (since we are in the bare repo root)
GIT_DIR=".git" git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

echo -e "${GREEN}[3/5] Fetching origin...${NC}"
GIT_DIR=".git" git fetch origin

# Determine default branch (HEAD points to it in the bare repo)
DEFAULT_BRANCH=$(GIT_DIR=".git" git symbolic-ref --short HEAD 2>/dev/null | sed 's|refs/heads/||') || DEFAULT_BRANCH="main"
echo -e "${BLUE}Detected default branch: $DEFAULT_BRANCH${NC}"

echo -e "${GREEN}[4/5] Creating '$DEFAULT_BRANCH' worktree...${NC}"
git worktree add "./$DEFAULT_BRANCH" "$DEFAULT_BRANCH"

echo -e "${GREEN}[5/5] Generating DevEx config...${NC}"
# Modify generating config to use the detected default branch
devex_generate_config "$(pwd)/.devex.conf" "$DEFAULT_BRANCH"

echo -e "\n${BLUE}✓ Bare clone and worktree created successfully!${NC}"
