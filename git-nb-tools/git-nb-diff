#!/usr/bin/env bash

# git-nb-diff
# Provides human-readable diffs for Jupyter Notebooks.

set -e

BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ "$#" -eq 0 ]; then
    echo "Usage: git nb diff <notebook1.ipynb> [arguments to git diff]"
    exit 1
fi

nb_file="$1"
shift

if command -v nbdiff &> /dev/null; then
    # Use nbdime if available
    nbdiff "$nb_file" "$@"
else
    # Fallback to standard git diff with a warning
    echo -e "${YELLOW}Warning: 'nbdime' is not installed. Falling back to raw JSON diff.${NC}" >&2
    echo -e "To get human-readable notebook diffs, run: ${BLUE}pip install nbdime${NC}" >&2
    echo ""
    git diff "$nb_file" "$@"
fi
