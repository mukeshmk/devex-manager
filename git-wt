#!/usr/bin/env bash

# DevEx Manager: Git Worktree Router
set -e

COMMAND="$1"
[ "$#" -gt 0 ] && shift

# Locate tools relative to this script
ROUTER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
TOOLS_DIR="$ROUTER_DIR/git-wt-tools"

BLUE='\033[0;34m'
NC='\033[0m'

case "$COMMAND" in
    clone)  "$TOOLS_DIR/git-wt-clone" "$@" ;;
    add)    "$TOOLS_DIR/git-wt-add" "$@" ;;
    rm)     "$TOOLS_DIR/git-wt-rm" "$@" ;;
    clean)  "$TOOLS_DIR/git-wt-clean" "$@" ;;
    status) "$TOOLS_DIR/git-wt-status" "$@" ;;

    # Pass-through to native git worktree
    lock|move|prune|repair|unlock)
        git worktree "$COMMAND" "$@"
        ;;

    list)
        if [ "$#" -eq 0 ]; then
            "$TOOLS_DIR/git-wt-status" "$@"
        else
            git worktree list "$@"
        fi
        ;;

    *)
        echo -e "${BLUE}DevEx Manager (git wt)${NC}"
        echo "Usage: git wt <command> [arguments]"
        echo ""
        echo "Available commands:"
        echo "  clone   - Initialize bare repo & main worktree"
        echo "  add     - Create/checkout worktree (by branch prefix)"
        echo "  rm      - Delete worktree folder & local branch"
        echo "  clean   - Interactively remove stale worktrees"
        echo "  status  - Rich status overview (alias: list)"
        echo ""
        echo "Native Git Commands Pass-through:"
        echo "  lock, move, prune, repair, unlock"
        exit 1
        ;;
esac
