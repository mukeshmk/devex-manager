#!/usr/bin/env bash

# The master router for all 'git wt' commands
COMMAND="$1"
shift # Remove the first argument so we only pass the remaining flags/args

# Dynamically find where this router script is installed
ROUTER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$ROUTER_DIR/git-wt-tools"

# Colors
BLUE='\033[0;34m'
NC='\033[0m'

case "$COMMAND" in
    clone)
        "$TOOLS_DIR/git-wt-clone" "$@"
        ;;
    add)
        "$TOOLS_DIR/git-wt-add" "$@"
        ;;
    rm)
        "$TOOLS_DIR/git-wt-rm" "$@"
        ;;
    clean)
        "$TOOLS_DIR/git-wt-clean" "$@"
        ;;
    status)
        "$TOOLS_DIR/git-wt-status" "$@"
        ;;
    # NATIVE GIT WORKTREE COMMANDS
    list|lock|move|prune|repair|unlock)
        # Passing these commands directly to the real git worktree
        git worktree "$COMMAND" "$@"
        ;;
    *)
        echo -e "${BLUE}DevEx Manager (git wt)${NC}"
        echo "Usage: git wt <command> [arguments]"
        echo ""
        echo "Available commands:"
        echo "  clone   - Clone a bare repo and set up the main worktree"
        echo "  add     - Create or checkout a worktree (uses branch prefix for folder)"
        echo "  rm      - Safely delete a worktree folder and its local branch"
        echo "  clean   - Interactively find and remove stale worktrees"
        echo "  status  - Show a rich status overview of all active worktrees"
        echo ""
        echo "Native Git Commands Pass-through:"
        echo "  list    - List details of each worktree"
        echo "  lock    - Prevent a worktree from being pruned"
        echo "  move    - Move a worktree to a new location"
        echo "  prune   - Prune working tree information"
        echo "  repair  - Repair worktree administrative files"
        echo "  unlock  - Unlock a worktree"
        exit 1
        ;;
esac
