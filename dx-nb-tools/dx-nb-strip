#!/usr/bin/env bash

# dx-nb-strip
# Clears outputs and metadata from Jupyter Notebooks.

set -e

BLUE='\033[0;34m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

if [ "$#" -eq 0 ]; then
    echo "Usage: dx nb strip <notebook1.ipynb> [notebook2.ipynb ...]"
    echo "Example: dx nb strip *.ipynb"
    exit 1
fi

if command -v nbstripout &> /dev/null; then
    echo -e "${BLUE}Stripping output from $# notebook(s) using nbstripout...${NC}"
    nbstripout "$@"
elif command -v jupyter &> /dev/null; then
    echo -e "${BLUE}Stripping output from $# notebook(s) using jupyter nbconvert...${NC}"
    jupyter nbconvert --clear-output --inplace "$@"
else
    echo -e "${RED}Error: Neither 'nbstripout' nor 'jupyter' (nbconvert) is installed.${NC}" >&2
    echo "Please install one of them to use this feature:" >&2
    echo "  pip install nbstripout" >&2
    echo "  pip install nbconvert" >&2
    exit 1
fi

echo -e "${GREEN}✓ Done.${NC}"
