#!/usr/bin/env bash

# DevEx Manager: DX Notebook Router
set -e

COMMAND="$1"
[ "$#" -gt 0 ] && shift

# Locate tools relative to this script
ROUTER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
TOOLS_DIR="$ROUTER_DIR"

BLUE='\033[0;34m'
NC='\033[0m'

case "$COMMAND" in
    strip)  "$TOOLS_DIR/dx-nb-strip" "$@" ;;
    diff)   "$TOOLS_DIR/dx-nb-diff" "$@" ;;
    kernel) "$TOOLS_DIR/dx-nb-kernel" "$@" ;;
    list)   "$TOOLS_DIR/dx-nb-list" "$@" ;;

    *)
        echo -e "${BLUE}DevEx Manager (dx nb)${NC}"
        echo "Usage: dx nb <command> [arguments]"
        echo ""
        echo "Available commands:"
        echo "  strip   - Clear outputs/metadata (bulk support)"
        echo "  diff    - Human-readable notebook diffs"
        echo "  kernel  - Register .venv as Jupyter kernel"
        echo "  list    - Recursive discovery & metadata reporting"
        echo ""
        exit 1
        ;;
esac
